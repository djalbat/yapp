{
  "name": "yapp",
  "author": "James Smith",
  "version": "5.1.335",
  "license": "MIT, Anti-996",
  "homepage": "https://github.com/djalbat/yapp",
  "description": "Yapp;s Another Pretty Printer.",
  "repository": {
    "type": "git",
    "url": "https://github.com/djalbat/yapp"
  },
  "dependencies": {
    "easy": "^25.0.1",
    "easy-richtextarea": "^4.0.337",
    "easy-with-style": "^3.0.566",
    "necessary": "^17.2.10",
    "occam-grammar-utilities": "^8.1.1",
    "occam-lexers": "^23.1.67",
    "occam-parsers": "^23.1.198",
    "occam-query": "^4.1.185"
  },
  "devDependencies": {
    "@swc/core": "1.13.20",
    "esbuild": "0.11.14",
    "easy-layout": "^6.0.320",
    "express": "^4.17.1",
    "juxtapose": "^4.0.138",
    "lively-cli": "^3.0.3",
    "watchful-cli": "^1.7.98"
  },
  "scripts": {
    "start": "node ./bin/main.js",
    "clean": "rm -rf ./lib",
    "watchful": "watchful -m --transpiler=swc --bundler=esbuild --source-directory=./src --lib-directory=./lib --entry-file=example.js --bundle-file=./example.js --wait=100",
    "batch": "npm run watchful batch --",
    "batch-debug": "npm run watchful batch -- --debug",
    "incremental": "npm run watchful incremental --",
    "incremental-debug": "npm run watchful incremental -- --debug",
    "build": "npm run clean && npm run batch",
    "build-debug": "npm run clean && npm run batch-debug",
    "watch": "npm run clean && npm run batch && npm run incremental",
    "watch-debug": "npm run clean && npm run batch-debug && npm run incremental-debug"
  },
  "files": [
    "src",
    "lib"
  ],
  "main": "./lib/index.js"
}
